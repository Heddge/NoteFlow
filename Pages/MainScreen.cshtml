@page
@using NoteFlow.Models
@using NoteFlow.Pages;
@using NoteFlow.Services;
@using NoteFlow.Helpers;
@using System.Text.Json;
@model NoteFlow.Pages.MainScreenModel;
@{
    ViewData["Title"] = "NoteFlow";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="~/js/ui-settings.js" asp-append-version="true"></script>
    <script>
        window.NoteFlowUiSettings?.boot();
    </script>
    <link rel="stylesheet" href="~/css/MainScreen.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/settings-modal.css" asp-append-version="true" />
</head>

<body>


    <button class="settings-btn" id="openSettingsBtn" type="button" title="Настройки" aria-label="Настройки">
        <svg class="settings-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3.2" />
            <path d="M19.4 15a1.8 1.8 0 0 0 .36 2.03l.08.08a2 2 0 1 1-2.83 2.83l-.08-.08a1.8 1.8 0 0 0-2.03-.36 1.8 1.8 0 0 0-1.06 1.64V22a2 2 0 1 1-4 0v-.12a1.8 1.8 0 0 0-1.06-1.64 1.8 1.8 0 0 0-2.03.36l-.08.08a2 2 0 1 1-2.83-2.83l.08-.08A1.8 1.8 0 0 0 4.6 15a1.8 1.8 0 0 0-1.64-1.06H2a2 2 0 1 1 0-4h.96A1.8 1.8 0 0 0 4.6 8.88a1.8 1.8 0 0 0-.36-2.03l-.08-.08a2 2 0 1 1 2.83-2.83l.08.08a1.8 1.8 0 0 0 2.03.36A1.8 1.8 0 0 0 10.16 2.5V2a2 2 0 1 1 4 0v.5a1.8 1.8 0 0 0 1.06 1.64 1.8 1.8 0 0 0 2.03-.36l.08-.08a2 2 0 1 1 2.83 2.83l-.08.08a1.8 1.8 0 0 0-.36 2.03 1.8 1.8 0 0 0 1.64 1.06H22a2 2 0 1 1 0 4h-.96A1.8 1.8 0 0 0 19.4 15z" />
        </svg>
    </button>

    <!-- Кнопка домой
    <button class="home-btn" onclick="goHome()">Домой</button> -->

    <!-- Всплывающее окно -->
    <div id="devModal" class="dev-modal" hidden>
        <div class="dev-modal-content">В разработке...</div>
    </div>
    <div id="devModalOverlay" class="dev-modal-overlay"></div>

    <div id="settingsModal" class="settings-modal" aria-hidden="true" role="dialog" aria-modal="true" hidden>
        <div class="settings-modal-content">
            <div class="settings-modal-header">
                <h2>Настройки</h2>
                <button class="settings-close" type="button" id="closeSettingsBtn" aria-label="Закрыть">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <div class="settings-layout">
                <section class="settings-panel settings-panel-primary">
                    <div class="settings-panel-heading">
                        <span class="settings-panel-kicker">Персонализация</span>
                        <h3>Оформление интерфейса</h3>
                    </div>

                    <div class="settings-control-group">
                        <div class="settings-control-label">Тема</div>
                        <div class="settings-choice-row">
                            <button type="button" class="settings-choice-btn" data-setting="theme" data-value="dark">Тёмная</button>
                            <button type="button" class="settings-choice-btn" data-setting="theme" data-value="light">Светлая</button>
                        </div>
                    </div>

                    <div class="settings-control-group">
                        <div class="settings-control-label">Шрифт</div>
                        <div class="settings-choice-grid">
                            <button type="button" class="settings-choice-btn settings-choice-btn-font" data-setting="font" data-value="inter">Inter</button>
                            <button type="button" class="settings-choice-btn settings-choice-btn-font" data-setting="font" data-value="manrope">Manrope</button>
                            <button type="button" class="settings-choice-btn settings-choice-btn-font" data-setting="font" data-value="plex">IBM Plex Sans</button>
                        </div>
                    </div>
                </section>

            </div>

            <div class="settings-sidebar-toggle">
                <div class="settings-sidebar-toggle-copy">
                    <div class="settings-sidebar-toggle-title">Автопоказывать сайдбар редактора</div>
                    <div class="settings-sidebar-toggle-text">Если выключить, экран редактирования будет открываться уже со скрытым сайдбаром.</div>
                </div>
                <label class="settings-switch" for="editorSidebarVisibleToggle">
                    <input type="checkbox" id="editorSidebarVisibleToggle" />
                    <span class="settings-switch-track">
                        <span class="settings-switch-thumb"></span>
                    </span>
                </label>
            </div>
        </div>
    </div>

    <div id="reminderModal" class="reminder-modal" aria-hidden="true" hidden>
        <div id="reminderModalContent" class="reminder-modal-content gradient-border">
            <div class="reminder-modal-glow reminder-modal-glow-left"></div>
            <div class="reminder-modal-glow reminder-modal-glow-right"></div>

            <div class="reminder-modal-header">
                <h2>Новое напоминание</h2>
                <p>Запланируй дату и время, чтобы карточка сразу появилась на главном экране.</p>
            </div>

            <form method="post" asp-page-handler="CreateReminder" class="reminder-form">
                <div class="reminder-form-column">
                    <label class="reminder-input-label" for="reminderTitle">Название</label>
                    <input id="reminderTitle" class="reminder-input" type="text" name="Title" placeholder="Например, позвонить по работе"
                        required maxlength="120" />

                    <label class="reminder-input-label" for="reminderDescription">Описание</label>
                    <textarea id="reminderDescription" class="reminder-textarea" name="Description"
                        placeholder="Коротко: что нужно сделать" rows="5" maxlength="280"></textarea>

                    <label class="reminder-repeat">
                        <input type="checkbox" name="IsRepeating" />
                        <span>Повторять ежедневно</span>
                    </label>
                </div>

                <div class="reminder-form-column">
                    <label class="reminder-input-label">Дата</label>
                    <div class="reminder-date-grid">
                        <select class="reminder-select" name="Day">
                            @for (int i = 1; i <= 31; i++)
                            {
                                if (i == DateTime.Now.Day)
                                {
                                    <option selected value="@i">@i</option>
                                }
                                else
                                {
                                    <option value="@i">@i</option>
                                }
                            }
                        </select>
                        <select class="reminder-select" name="Month">
                            @for (int i = 1; i <= 12; i++)
                            {
                                if (i == DateTime.Now.Month)
                                {
                                    <option selected value="@i">@i</option>
                                }
                                else
                                {
                                    <option value="@i">@i</option>
                                }
                            }
                        </select>
                        <select class="reminder-select" name="Year">
                            @for (int i = DateTime.Now.Year; i <= DateTime.Now.Year + 5; i++)
                            {
                                if (i == DateTime.Now.Year)
                                {
                                    <option selected value="@i">@i</option>
                                }
                                else
                                {
                                    <option value="@i">@i</option>
                                }
                            }
                        </select>
                    </div>

                    <label class="reminder-input-label" for="reminderTime">Время</label>
                    <input id="reminderTime" class="reminder-input" type="time" name="Time" value="@DateTime.Now.ToString("HH:mm")" required />
                </div>

                <div class="reminder-form-actions">
                    <button type="button" class="reminder-btn reminder-btn-secondary" onclick="closeReminderModal()">Отмена</button>
                    <button type="submit" class="reminder-btn reminder-btn-primary">Добавить</button>
                </div>
            </form>
        </div>
    </div>

    <button id="toggleSidebarBtn" class="toggle-sidebar-btn">
        <div class="toggle-icon">
            <div class="toggle-icon-line"></div>
            <div class="toggle-icon-line"></div>
            <div class="toggle-icon-line"></div>
        </div>
    </button>


    <div class="add-text">
        <strong>
            <h1 class="add-text">Greetings</h1>
        </strong>
    </div>

    <nav class="top-bar">
        <div class="logo-container">
            <img src="/Images/Logo.png" class="logo" alt="NoteFlow" />
        </div>

        <div class="top-bar-actions">
            @if (PlatformHelper.IsMacOS)
            {
                <!-- macOS стиль - кнопки слева -->
                <div class="top-bar-actions macos-buttons">
                    <button class="nav-buttons close-btn" title="Закрыть" id="closeBtn">
                        <svg width="12" height="12" viewBox="0 0 12 12">
                            <circle cx="6" cy="6" r="6" fill="#FF5F57" />
                        </svg>
                    </button>
                    <button class="nav-buttons" title="Свернуть" id="minimizeBtn">
                        <svg width="12" height="12" viewBox="0 0 12 12">
                            <circle cx="6" cy="6" r="6" fill="#FFBD2E" />
                        </svg>
                    </button>
                    <button class="nav-buttons" title="Развернуть" id="maximizeBtn">
                        <svg width="12" height="12" viewBox="0 0 12 12">
                            <circle cx="6" cy="6" r="6" fill="#28CA42" />
                        </svg>
                    </button>
                </div>
            }
            else
            {
                <div class="top-bar-actions windows-buttons">
                    <button class="nav-buttons" title="Перезагрузить" id="reloadBtn">
                        <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M23 4v6h-6M1 20v-6h6" stroke-width="2" stroke-linecap="round" />
                            <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" stroke-width="2"
                                stroke-linecap="round" />
                        </svg>
                    </button>
                    <button class="nav-buttons" title="Свернуть" id="minimizeBtn">
                        <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M5 12h14" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </button>
                    <button class="nav-buttons" title="Развернуть" id="maximizeBtn">
                        <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2" />
                        </svg>
                    </button>
                    <button class="nav-buttons close-btn" title="Закрыть" id="closeBtn">
                        <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path d="M18 6L6 18M6 6l12 12" stroke-width="2" stroke-linecap="round" />
                        </svg>
                    </button>
                </div>
            }
        </div>

    </nav>
    <!-- Надпись "Недавние файлы" -->
    <div class="recent-files-label">Недавние файлы</div>

    <!-- Обертка для контейнера с блюром -->
    <div class="cards-container-wrapper">
        <div class="blur">
            <img src="/Images/blur.png" alt="NoteFlow" />
        </div>
        <!-- Контейнер для карточек заметок -->
        <div class="cards-container">
            <!-- Карточка добавления заметки -->
            <form method="post">
                <button type="submit" asp-page-handler="ToEditorForEditOrCreate" name="path" value=""
                    class="card-button">
                    <div class="card-bg">
                        <div class="add-note-text">Добавить заметку</div>
                    </div>
                </button>
            </form>

            <!-- Карточки заметок -->
            @if (Model.NotesDict.Count() > 0)
                @foreach (KeyValuePair<string, Note> pair in Model.NotesDict)
                    {
                        <form method="post" asp-page-handler="ToEditorForEditOrCreate">
                        <input type="hidden" name="path" value="@pair.Value.NotePath" />
                        <button type="submit" class="note-card">
                            <div class="note-card-bg">
                                <div class="note-icon">&lt;/&gt;</div>
                                <div class="note-title">@pair.Value.NoteTitle</div>
                                <div class="note-description">@Html.Raw(pair.Value.NoteContent)</div>
                                <div class="note-timestamp">@pair.Value.BeatifulCreationDate()</div>
                            </div>
                        </button>
                    </form>
                    }

            @* @if (Model.NotesDict.Count() > 0)
                @for (int i = 0; i < Model.NotesDict.Count(); i++)
                {
                    <form method="post" asp-page-handler="ToEditorForEditOrCreate">
                        <input type="hidden" name="path" value="@Model.Notes[i].NotePath" />
                        <button type="submit" class="note-card">
                            <div class="note-card-bg">
                                <div class="note-title">@Model.Notes[i].NoteTitle</div>
                                <div class="note-description">@Html.Raw(Model.Notes[i].NoteContent)</div>
                                <div class="note-timestamp">@Model.Notes[i].BeatifulCreationDate()</div>
                            </div>
                        </button>
                    </form>
                } *@
        </div>
    </div>

    <!-- НАДПИСЬ НАПОМИНАНИЯ -->
    <div class="reminders-label">Напоминания</div>

    <!-- Контейнер для напоминаний -->
    <div class="reminders-container">
        <div class="blur">
            <img src="/Images/blur.png" alt="NoteFlow" />
        </div>

        <div class="cards-container">
            <!-- Карточка нового напоминания -->
            <div class="card add-reminder-card" onclick="showReminderModal()">
                <div class="card-bg">
                    <div class="add-note-text">Добавить напоминание</div>
                </div>
            </div>

            @if (Model.Reminders.Count() > 0)
            {
                foreach (var reminder in Model.Reminders)
                {
                    <div class="wide-reminder-card reminder-card-enter">
                        <div class="wide-reminder-bg gradient-border">
                            <form method="post" asp-page-handler="DeleteReminder" class="reminder-delete-form">
                                <input type="hidden" name="path" value="@reminder.ReminderPath" />
                                <button type="submit" class="reminder-delete-btn" title="Удалить напоминание">×</button>
                            </form>

                            <div class="reminder-time-header-container">
                                <div class="reminder-date">@reminder.GetExpiringDayLabel()</div>
                                <div class="reminder-time">@reminder.GetExpiringTimeLabel()</div>
                            </div>

                            <div class="reminder-content-box">
                                <div class="reminder-main-text">@reminder.ReminderTitle</div>
                                <div class="reminder-description-text">
                                    @(string.IsNullOrWhiteSpace(reminder.ReminderDescription) ? "Без описания" : reminder.ReminderDescription)
                                </div>
                            </div>

                            <div class="reminder-created-time-container">
                                <div class="reminder-created-time">
                                    Создано @reminder.BeatifulCreationDate()@(reminder.IsRepeating ? " • повтор" : "")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="wide-reminder-card reminder-card-enter">
                    <div class="wide-reminder-bg gradient-border reminder-empty-card">
                        <div class="reminder-main-text">Пока нет активных напоминаний</div>
                        <div class="reminder-description-text">Нажми «Добавить напоминание», чтобы создать первое.</div>
                    </div>
                </div>
            }
        </div>
    </div>




    <!-- Календарь -->
    <div class="calendar-section-title">Календарь</div>
    <div class="calendar-section-wrapper">
        <div class="calendar-container gradient-border">
            <div class="calendar-content">
                <div class="calendar-left">
                    <div id="calendarCurrentDate" class="calendar-current-date"></div>
                    <div id="calendarReminderList" class="calendar-reminder-list"></div>
                </div>

                <div class="calendar-compact gradient-border">
                    <div class="calendar-header-compact">
                        <div class="calendar-nav">
                            <button type="button" id="calendarPrevBtn" class="calendar-nav-btn">&lt;</button>
                            <div id="calendarMonthYear" class="calendar-month-year"></div>
                            <button type="button" id="calendarNextBtn" class="calendar-nav-btn">&gt;</button>
                        </div>
                    </div>

                    <div class="calendar-week-days-compact">
                        <div class="calendar-week-day">ВС</div>
                        <div class="calendar-week-day">ПН</div>
                        <div class="calendar-week-day">ВТ</div>
                        <div class="calendar-week-day">СР</div>
                        <div class="calendar-week-day">ЧТ</div>
                        <div class="calendar-week-day">ПТ</div>
                        <div class="calendar-week-day">СБ</div>
                    </div>

                    <div id="calendarDaysGrid" class="calendar-days-grid"></div>
                </div>
            </div>
        </div>
    </div>

    <form id="calendarReminderDeleteTemplate" method="post" asp-page-handler="DeleteReminder" hidden aria-hidden="true">
        <input type="hidden" name="path" value="" />
        <button type="submit" class="calendar-reminder-delete-btn" title="Удалить напоминание" aria-label="Удалить напоминание">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 6L6 18M6 6l12 12" />
            </svg>
        </button>
    </form>

    <script>
        const { ipcRenderer } = require('electron');

        document.getElementById('minimizeBtn')?.addEventListener('click', () => {
            ipcRenderer.send('minimize-window');
        });

        document.getElementById('maximizeBtn')?.addEventListener('click', () => {
            ipcRenderer.send('maximize-window');
        });

        document.getElementById('closeBtn')?.addEventListener('click', () => {
            ipcRenderer.send('close-window');
        });

        document.getElementById('reloadBtn')?.addEventListener('click', () => {
            location.reload();
        });

        const uiSettingsApi = window.NoteFlowUiSettings;
        const uiSettingsDefaults = uiSettingsApi?.defaults ?? {
            theme: 'dark',
            font: 'inter',
            editorSidebarVisible: true
        };
        let uiSettings = uiSettingsApi?.read() ?? { ...uiSettingsDefaults };

        const remindersData = @Html.Raw(JsonSerializer.Serialize(
            Model.Reminders.Select(r => new
            {
                path = r.ReminderPath,
                title = r.ReminderTitle,
                description = r.ReminderDescription,
                expiresAt = r.ReminderExpires,
                isRepeating = r.IsRepeating
            })
        ));

    @*function openSettings() {
            console.log('Открыть настройки');
            window.location.href = '/Settings';
        }*@

            function goHome() {
                console.log('Возврат на главный экран');
                window.location.href = '/MainScreen';
            }

        // Горизонтальный скролл карточек + динамические fade/индикатор
        const cardsContainers = document.querySelectorAll('.cards-container');
        const horizontalScrollShellSelector = '.cards-container-wrapper, .reminders-container';
        const SCROLLING_CLASS_TIMEOUT_MS = 480;

        function ensureHorizontalScrollIndicator(shell) {
            if (!shell || shell.querySelector('.scroll-progress')) {
                return;
            }

            const indicator = document.createElement('div');
            indicator.className = 'scroll-progress';
            shell.appendChild(indicator);
        }

        function updateHorizontalScrollState(container) {
            const shell = container.closest(horizontalScrollShellSelector);
            if (!shell) {
                return;
            }

            const maxScroll = Math.max(0, container.scrollWidth - container.clientWidth);
            const currentScroll = Math.max(0, container.scrollLeft);
            const hasOverflow = maxScroll > 1;

            shell.classList.toggle('has-horizontal-overflow', hasOverflow);
            shell.classList.toggle('has-left-overflow', hasOverflow && currentScroll > 2);
            shell.classList.toggle('has-right-overflow', hasOverflow && currentScroll < (maxScroll - 2));

            const progress = hasOverflow ? Math.max(0.08, Math.min(1, currentScroll / maxScroll)) : 0;
            shell.style.setProperty('--scroll-progress', progress.toFixed(4));
        }

        cardsContainers.forEach((cardsContainerItem) => {
            const shell = cardsContainerItem.closest(horizontalScrollShellSelector);
            let scrollingTimer = null;

            ensureHorizontalScrollIndicator(shell);

            const markScrolling = () => {
                if (!shell) {
                    return;
                }

                shell.classList.add('is-scrolling');
                if (scrollingTimer) {
                    clearTimeout(scrollingTimer);
                }

                scrollingTimer = setTimeout(() => {
                    shell.classList.remove('is-scrolling');
                }, SCROLLING_CLASS_TIMEOUT_MS);
            };

            cardsContainerItem.addEventListener('wheel', function (e) {
                if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) {
                    return;
                }

                const maxScroll = Math.max(0, this.scrollWidth - this.clientWidth);
                if (maxScroll <= 0) {
                    return;
                }

                const targetScroll = Math.max(
                    0,
                    Math.min(maxScroll, this.scrollLeft + (e.deltaY * 1.9))
                );

                // Не блокируем вертикальный скролл страницы, если уткнулись в край.
                if (Math.abs(targetScroll - this.scrollLeft) < 0.5) {
                    return;
                }

                e.preventDefault();
                this.scrollLeft = targetScroll;
                updateHorizontalScrollState(this);
                markScrolling();
            }, { passive: false });

            cardsContainerItem.addEventListener('scroll', () => {
                updateHorizontalScrollState(cardsContainerItem);
                markScrolling();
            }, { passive: true });

            updateHorizontalScrollState(cardsContainerItem);
        });

        window.addEventListener('resize', () => {
            cardsContainers.forEach((cardsContainerItem) => updateHorizontalScrollState(cardsContainerItem));
        });

        window.addEventListener('load', () => {
            cardsContainers.forEach((cardsContainerItem) => updateHorizontalScrollState(cardsContainerItem));
        });

        const devModal = document.getElementById('devModal');
        const settingsModal = document.getElementById('settingsModal');
        const reminderModal = document.getElementById('reminderModal');
        const devModalOverlay = document.getElementById('devModalOverlay');
        const openSettingsBtn = document.getElementById('openSettingsBtn');
        const closeSettingsBtn = document.getElementById('closeSettingsBtn');
        const editorSidebarVisibleToggle = document.getElementById('editorSidebarVisibleToggle');
        const settingsChoiceButtons = document.querySelectorAll('.settings-choice-btn');
        const MODAL_ANIMATION_MS = 260;
        let activeModal = null;

        function persistUiSettings(nextSettings) {
            uiSettings = uiSettingsApi?.write(nextSettings) ?? { ...uiSettings, ...nextSettings };
            return uiSettings;
        }

        function syncSettingsControls() {
            settingsChoiceButtons.forEach((button) => {
                const isActive = uiSettings[button.dataset.setting] === button.dataset.value;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            });

            if (editorSidebarVisibleToggle) {
                editorSidebarVisibleToggle.checked = uiSettings.editorSidebarVisible;
            }
        }

        syncSettingsControls();

        function showDevModal() {
            openModal(devModal);
        }

        function showSettingsModal() {
            openModal(settingsModal);
        }

        function showReminderModal() {
            openModal(reminderModal);
        }

        function closeReminderModal() {
            closeModal(reminderModal);
        }

        function openModal(modalElement) {
            if (!modalElement) {
                return;
            }

            if (activeModal && activeModal !== modalElement) {
                closeModal(activeModal, true);
            }

            activeModal = modalElement;
            modalElement.hidden = false;
            devModalOverlay.classList.add('is-visible');
            modalElement.classList.remove('is-closing');
            modalElement.classList.add('is-active');
            modalElement.setAttribute('aria-hidden', 'false');
            syncModalVisibilityState();
        }

        function closeModal(modalElement, instantly = false) {
            if (!modalElement) {
                return;
            }

            modalElement.setAttribute('aria-hidden', 'true');

            if (instantly) {
                modalElement.classList.remove('is-active');
                modalElement.classList.remove('is-closing');
                modalElement.hidden = true;
            } else {
                modalElement.classList.remove('is-active');
                modalElement.classList.add('is-closing');

                setTimeout(() => {
                    modalElement.classList.remove('is-closing');
                    modalElement.hidden = true;
                    if (activeModal === modalElement) {
                        activeModal = null;
                    }

                    if (!isAnyModalVisible()) {
                        devModalOverlay.classList.remove('is-visible');
                    }

                    syncModalVisibilityState();
                }, MODAL_ANIMATION_MS);
            }

            if (activeModal === modalElement) {
                activeModal = null;
            }

            if (!isAnyModalVisible()) {
                devModalOverlay.classList.remove('is-visible');
            }

            syncModalVisibilityState();
        }

        function isAnyModalVisible() {
            return devModal.classList.contains('is-active')
                || devModal.classList.contains('is-closing')
                || settingsModal.classList.contains('is-active')
                || settingsModal.classList.contains('is-closing')
                || reminderModal.classList.contains('is-active')
                || reminderModal.classList.contains('is-closing');
        }

        function syncModalVisibilityState() {
            document.body.classList.toggle('modal-open', isAnyModalVisible());
        }

        if (openSettingsBtn) {
            openSettingsBtn.addEventListener('click', () => showSettingsModal());
        }

        if (closeSettingsBtn) {
            closeSettingsBtn.addEventListener('click', () => closeModal(settingsModal));
        }

        settingsChoiceButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const settingName = button.dataset.setting;
                const settingValue = button.dataset.value;

                if (!settingName || !settingValue) {
                    return;
                }

                persistUiSettings({ [settingName]: settingValue });
                syncSettingsControls();
            });
        });

        if (editorSidebarVisibleToggle) {
            editorSidebarVisibleToggle.addEventListener('change', (event) => {
                const nextValue = Boolean(event.target.checked);
                persistUiSettings({ editorSidebarVisible: nextValue });
                syncSettingsControls();
            });
        }

        devModalOverlay.addEventListener('click', function () {
            if (activeModal) {
                closeModal(activeModal);
                return;
            }

            closeModal(devModal, true);
            closeModal(settingsModal, true);
            closeModal(reminderModal, true);
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                if (activeModal) {
                    closeModal(activeModal);
                    return;
                }

                closeModal(devModal, true);
                closeModal(settingsModal, true);
                closeModal(reminderModal, true);
            }
        });

        const calendarCurrentDate = document.getElementById('calendarCurrentDate');
        const calendarReminderList = document.getElementById('calendarReminderList');
        const calendarMonthYear = document.getElementById('calendarMonthYear');
        const calendarDaysGrid = document.getElementById('calendarDaysGrid');
        const calendarPrevBtn = document.getElementById('calendarPrevBtn');
        const calendarNextBtn = document.getElementById('calendarNextBtn');
        const calendarReminderDeleteTemplate = document.getElementById('calendarReminderDeleteTemplate');

        const today = new Date();
        const calendarState = {
            selectedDate: new Date(today.getFullYear(), today.getMonth(), today.getDate()),
            viewYear: today.getFullYear(),
            viewMonth: today.getMonth()
        };

        function normalizeDate(date) {
            return new Date(date.getFullYear(), date.getMonth(), date.getDate());
        }

        function isSameDay(a, b) {
            return a.getFullYear() === b.getFullYear()
                && a.getMonth() === b.getMonth()
                && a.getDate() === b.getDate();
        }

        function formatDateLabel(date) {
            return date.toLocaleDateString('ru-RU', {
                day: 'numeric',
                month: 'long'
            });
        }

        function formatMonthYear(date) {
            const text = date.toLocaleDateString('ru-RU', {
                month: 'long',
                year: 'numeric'
            });

            return text.charAt(0).toUpperCase() + text.slice(1);
        }

        function parseReminderDate(reminder) {
            const value = new Date(reminder.expiresAt);
            return Number.isNaN(value.getTime()) ? null : value;
        }

        function reminderOccursOnDate(reminder, date) {
            const expiresAt = parseReminderDate(reminder);
            if (!expiresAt) {
                return false;
            }

            const reminderDay = normalizeDate(expiresAt);
            if (reminder.isRepeating) {
                return date >= reminderDay;
            }

            return isSameDay(reminderDay, date);
        }

        function getRemindersForDate(date) {
            return remindersData
                .map((reminder) => {
                    const expiresAt = parseReminderDate(reminder);
                    if (!expiresAt) {
                        return null;
                    }

                    return {
                        ...reminder,
                        expiresAtDate: expiresAt
                    };
                })
                .filter((reminder) => reminder && reminderOccursOnDate(reminder, date))
                .sort((a, b) => {
                    const left = (a.expiresAtDate.getHours() * 60) + a.expiresAtDate.getMinutes();
                    const right = (b.expiresAtDate.getHours() * 60) + b.expiresAtDate.getMinutes();
                    return left - right;
                });
        }

        function createCalendarReminderDeleteForm(reminder) {
            if (!calendarReminderDeleteTemplate || !reminder?.path) {
                return null;
            }

            const deleteForm = calendarReminderDeleteTemplate.cloneNode(true);
            deleteForm.removeAttribute('id');
            deleteForm.hidden = false;
            deleteForm.removeAttribute('aria-hidden');
            deleteForm.classList.add('calendar-reminder-delete-form');

            const pathInput = deleteForm.querySelector('input[name="path"]');
            if (pathInput) {
                pathInput.value = reminder.path;
            }

            return deleteForm;
        }

        function renderCalendarReminderList() {
            if (!calendarReminderList || !calendarCurrentDate) {
                return;
            }

            const reminders = getRemindersForDate(calendarState.selectedDate);
            calendarCurrentDate.textContent = formatDateLabel(calendarState.selectedDate);
            calendarReminderList.innerHTML = '';

            if (!reminders.length) {
                const empty = document.createElement('div');
                empty.className = 'calendar-reminder-empty';
                empty.textContent = 'На выбранный день напоминаний нет';
                calendarReminderList.appendChild(empty);
                return;
            }

            reminders.slice(0, 5).forEach((reminder) => {
                const item = document.createElement('div');
                item.className = 'calendar-reminder-item';

                const time = document.createElement('div');
                time.className = 'calendar-reminder-item-time';
                time.textContent = reminder.expiresAtDate.toLocaleTimeString('ru-RU', {
                    hour: '2-digit',
                    minute: '2-digit'
                });

                const title = document.createElement('div');
                title.className = 'calendar-reminder-item-title';
                title.textContent = reminder.title || 'Без названия';

                const description = document.createElement('div');
                description.className = 'calendar-reminder-item-description';
                description.textContent = reminder.description || 'Без описания';

                const deleteForm = createCalendarReminderDeleteForm(reminder);

                item.appendChild(time);
                item.appendChild(title);
                item.appendChild(description);
                if (deleteForm) {
                    item.appendChild(deleteForm);
                }
                calendarReminderList.appendChild(item);
            });
        }

        function renderCalendarGrid() {
            if (!calendarDaysGrid || !calendarMonthYear) {
                return;
            }

            const monthStart = new Date(calendarState.viewYear, calendarState.viewMonth, 1);
            const daysInMonth = new Date(calendarState.viewYear, calendarState.viewMonth + 1, 0).getDate();
            const leadingEmptyDays = monthStart.getDay();
            const currentToday = normalizeDate(new Date());

            calendarMonthYear.textContent = formatMonthYear(monthStart);
            calendarDaysGrid.innerHTML = '';

            for (let i = 0; i < leadingEmptyDays; i++) {
                const empty = document.createElement('div');
                empty.className = 'calendar-day empty';
                calendarDaysGrid.appendChild(empty);
            }

            for (let day = 1; day <= daysInMonth; day++) {
                const cellDate = new Date(calendarState.viewYear, calendarState.viewMonth, day);
                const dayCell = document.createElement('button');
                dayCell.type = 'button';
                dayCell.className = 'calendar-day';
                dayCell.textContent = `${day}`;

                if (isSameDay(cellDate, calendarState.selectedDate)) {
                    dayCell.classList.add('current');
                } else if (isSameDay(cellDate, currentToday)) {
                    dayCell.classList.add('today');
                }

                if (getRemindersForDate(cellDate).length > 0) {
                    dayCell.classList.add('has-reminders');
                }

                dayCell.addEventListener('click', () => {
                    calendarState.selectedDate = cellDate;
                    renderCalendarGrid();
                    renderCalendarReminderList();
                });

                calendarDaysGrid.appendChild(dayCell);
            }
        }

        function switchCalendarMonth(offset) {
            const target = new Date(calendarState.viewYear, calendarState.viewMonth + offset, 1);
            calendarState.viewYear = target.getFullYear();
            calendarState.viewMonth = target.getMonth();

            if (calendarState.selectedDate.getFullYear() !== calendarState.viewYear
                || calendarState.selectedDate.getMonth() !== calendarState.viewMonth) {
                calendarState.selectedDate = new Date(calendarState.viewYear, calendarState.viewMonth, 1);
            }

            renderCalendarGrid();
            renderCalendarReminderList();
        }

        calendarPrevBtn?.addEventListener('click', () => switchCalendarMonth(-1));
        calendarNextBtn?.addEventListener('click', () => switchCalendarMonth(1));

        renderCalendarGrid();
        renderCalendarReminderList();
    </script>

</body>
