@page "{notePath}"
@using NoteFlow.Models
@using NoteFlow.Pages;
@using NoteFlow.Helpers;
@model NoteFlow.Pages.NoteScreenModel;
@{
    ViewData["Title"] = "NoteFlow";
    Layout = null;
}

<!DOCTYPE html>
<head>
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="~/js/ui-settings.js" asp-append-version="true"></script>
    <script>
        window.NoteFlowUiSettings?.boot();
    </script>
    <link rel="stylesheet" href="~/css/NoteScreen.css">
    <link rel="stylesheet" href="~/css/settings-modal.css" asp-append-version="true" />
</head>

<body>
    <nav class="top-bar">
        @if (PlatformHelper.IsMacOS)
        {
            <div class="top-bar-actions macos-buttons">
                <button class="nav-buttons" title="На главную" id="backBtn">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button class="nav-buttons close-btn" id="closeBtn">
                    <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="#FF5F57" /></svg>
                </button>
                <button class="nav-buttons" id="minimizeBtn">
                    <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="#FFBD2E" /></svg>
                </button>
                <button class="nav-buttons" id="maximizeBtn">
                    <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="#28CA42" /></svg>
                </button>
            </div>
        }
        else
        {
            <div class="top-bar-actions windows-buttons">
                <button class="nav-buttons" title="На главную" id="backBtn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button class="nav-buttons" id="minimizeBtn">
                    <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M5 12h14" stroke-width="2" /></svg>
                </button>
                <button class="nav-buttons" id="maximizeBtn">
                    <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2" /></svg>
                </button>
                <button class="nav-buttons close-btn" id="closeBtn">
                    <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 6L6 18M6 6l12 12" stroke-width="2" /></svg>
                </button>
            </div>
        }
    </nav>

    <div id="contextMenu" class="context-menu">
        <button onclick="colorText('red')">Красный</button>
        <button onclick="colorText('blue')">Синий</button>
        <button onclick="colorText('green')">Зеленый</button>
        <button onclick="colorText('yellow')">Желтый</button>
        <button onclick="colorText('purple')">Фиолетовый</button>
        <button onclick="colorText('white')">Белый</button>
        <hr>
        <button onclick="changeFontSize('plain')">Текст</button>
        <button onclick="changeFontSize('big')">Заголовок 2</button>
        <button onclick="changeFontSize('very-big')">Заголовок 1</button>
    </div>

    <div class="main-content" style="overflow-y: visible">
        <form method="post" asp-page-handler="CreateOrEditNote">
            <input type="hidden" name="path" value="@Model._path" />
            <input type="Text" asp-for="NoteTitle" class="note-title-input" placeholder="Новая заметка" maxlength="35" />
            <input asp-for="NoteContent" type="hidden" id="NoteContent" />

            <div class="editor-container">
                @* ВАЖНО: тег ниже в одну строку без пробелов, чтобы работал плейсхолдер *@
                <div id="richTextEditor" contenteditable="true" data-placeholder="Введите ваш текст...">@Html.Raw(Model.NoteContent)</div>
            </div>
            <button type="button" onclick="saveNote()" class="save-button" title="Сохранить заметку" aria-label="Сохранить заметку">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#cccccc" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14,2 14,8 20,8" />
                    <line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10,9 9,9 9,11" />
                </svg>
            </button>
        </form>

        <form method="post">
            <input type="hidden" name="path" value="@Model._path"/>
            <button asp-page-handler="DeleteNote" type="submit" class="delete-button" title="Удалить заметку" aria-label="Удалить заметку">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#cccccc" stroke-width="1.5">
                    <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    <line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/>
                </svg>
            </button>
        </form>
    </div>

    <div id="devModal" class="dev-modal" hidden><div class="dev-modal-content">В разработке...</div></div>
    <div id="devModalOverlay" class="dev-modal-overlay"></div>

    <div id="settingsModal" class="settings-modal" aria-hidden="true" role="dialog" aria-modal="true" hidden>
        <div class="settings-modal-content">
            <div class="settings-modal-header">
                <h2>Настройки</h2>
                <button class="settings-close" type="button" id="closeSettingsBtn" aria-label="Закрыть">
                    <span aria-hidden="true">×</span>
                </button>
            </div>

            <div class="settings-layout">
                <section class="settings-panel settings-panel-primary">
                    <div class="settings-panel-heading">
                        <span class="settings-panel-kicker">Персонализация</span>
                        <h3>Оформление интерфейса</h3>
                    </div>

                    <div class="settings-control-group">
                        <div class="settings-control-label">Тема</div>
                        <div class="settings-choice-row">
                            <button type="button" class="settings-choice-btn" data-setting="theme" data-value="dark">Тёмная</button>
                            <button type="button" class="settings-choice-btn" data-setting="theme" data-value="light">Светлая</button>
                        </div>
                    </div>

                    <div class="settings-control-group">
                        <div class="settings-control-label">Шрифт</div>
                        <div class="settings-choice-grid">
                            <button type="button" class="settings-choice-btn settings-choice-btn-font" data-setting="font" data-value="inter">Inter</button>
                            <button type="button" class="settings-choice-btn settings-choice-btn-font" data-setting="font" data-value="manrope">Manrope</button>
                            <button type="button" class="settings-choice-btn settings-choice-btn-font" data-setting="font" data-value="plex">IBM Plex Sans</button>
                        </div>
                    </div>
                </section>

            </div>

            <div class="settings-sidebar-toggle">
                <div class="settings-sidebar-toggle-copy">
                    <div class="settings-sidebar-toggle-title">Автопоказывать сайдбар редактора</div>
                    <div class="settings-sidebar-toggle-text">Если выключить, экран редактирования будет открываться уже со скрытым сайдбаром.</div>
                </div>
                <label class="settings-switch" for="editorSidebarVisibleToggle">
                    <input type="checkbox" id="editorSidebarVisibleToggle" />
                    <span class="settings-switch-track">
                        <span class="settings-switch-thumb"></span>
                    </span>
                </label>
            </div>
        </div>
    </div>

    <button id="toggleSidebarBtn" class="toggle-sidebar-btn">
        <div class="toggle-icon">
            <div class="toggle-icon-line"></div><div class="toggle-icon-line"></div><div class="toggle-icon-line"></div>
        </div>
    </button>

    <aside id="sidebar" class="sidebar">
        <div class="sidebar-section">
            <div id="sidebarSearchBtn" class="sidebar-item" onclick="toggleSidebarSearch()">
                <div class="sidebar-icon"><svg width="22" height="22" viewBox="0 0 27 27" fill="none"><circle cx="11" cy="11" r="8" stroke="#A6A6A6" stroke-width="2"/><path d="M18.5 17.5L25 24" stroke="#A6A6A6" stroke-width="2"/></svg></div>
                <div class="sidebar-title">Поиск</div>
            </div>
            <button type="button" class="sidebar-item sidebar-item-button" onclick="goToNewNote()">
                <div class="sidebar-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#A6A6A6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 5V19" />
                        <path d="M5 12H19" />
                    </svg>
                </div>
                <div class="sidebar-title">РќРѕРІР°СЏ Р·Р°РјРµС‚РєР°</div>
            </button>
            <div class="sidebar-item" onclick="goHome()">
                <div class="sidebar-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                        <path d="M3 10.5L12 3L21 10.5" stroke="#A6A6A6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M6 9.5V20H18V9.5" stroke="#A6A6A6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="sidebar-title">Домой</div>
            </div>
            <div class="sidebar-item" onclick="showSettingsModal()">
                <div class="sidebar-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#A6A6A6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3.2" />
                        <path d="M19.4 15a1.8 1.8 0 0 0 .36 2.03l.08.08a2 2 0 1 1-2.83 2.83l-.08-.08a1.8 1.8 0 0 0-2.03-.36 1.8 1.8 0 0 0-1.06 1.64V22a2 2 0 1 1-4 0v-.12a1.8 1.8 0 0 0-1.06-1.64 1.8 1.8 0 0 0-2.03.36l-.08.08a2 2 0 1 1-2.83-2.83l.08-.08A1.8 1.8 0 0 0 4.6 15a1.8 1.8 0 0 0-1.64-1.06H2a2 2 0 1 1 0-4h.96A1.8 1.8 0 0 0 4.6 8.88a1.8 1.8 0 0 0-.36-2.03l-.08-.08a2 2 0 1 1 2.83-2.83l.08.08a1.8 1.8 0 0 0 2.03.36A1.8 1.8 0 0 0 10.16 2.5V2a2 2 0 1 1 4 0v.5a1.8 1.8 0 0 0 1.06 1.64 1.8 1.8 0 0 0 2.03-.36l.08-.08a2 2 0 1 1 2.83 2.83l-.08.08a1.8 1.8 0 0 0-.36 2.03 1.8 1.8 0 0 0 1.64 1.06H22a2 2 0 1 1 0 4h-.96A1.8 1.8 0 0 0 19.4 15z" />
                    </svg>
                </div>
                <div class="sidebar-title">Настройки</div>
            </div>
        </div>

        <div id="sidebarSearchPanel" class="sidebar-search-panel" aria-hidden="true">
            <form id="sidebarSearchForm" class="sidebar-search-form">
                <input id="sidebarSearchInput" class="sidebar-search-input" type="text" placeholder="Search by note title" />
            </form>
        </div>

        <div class="recent-files-section">
            <div class="recent-files-title" id="recentFilesTitle">Недавние файлы</div>
            <div class="file-list" id="recentFilesList">
                @* Место для цикла из бэкенда *@
                @foreach (var note in @Model.GetNotesDict()) 
                {
                    <div class="file-item-row searchable-note-row" data-note-title="@note.Value.NoteTitle">
                        <form method="post" asp-page-handler="RedirectToNote">
                            <input type="hidden" name="path" value="@note.Key" />
                            <button type="submit" class="file-item">
                                <div class="file-icon">N</div>
                                <div class="file-title">@note.Value.NoteTitle</div>
                            </button>
                        </form>
                        <form method="post" asp-page-handler="DeleteNoteFromNoteScreen" class="file-remove-form">
                            <input type="hidden" name="path" value="@note.Key" />
                            <button type="submit" class="file-remove-btn" aria-label="Delete note">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                            </button>
                        </form>
                    </div>
                }
            </div>
            <div id="sidebarSearchEmpty" class="sidebar-search-empty" hidden>No matching notes</div>
        </div>
    </aside>

    <script>
        const { ipcRenderer } = require('electron');
        const uiSettingsApi = window.NoteFlowUiSettings;
        const uiSettingsDefaults = uiSettingsApi?.defaults ?? {
            theme: 'dark',
            font: 'inter',
            editorSidebarVisible: true
        };
        let uiSettings = uiSettingsApi?.read() ?? { ...uiSettingsDefaults };
        const newNoteUrl = '@Url.Page("/NoteScreen", new { notePath = "a" })';

        document.getElementById('minimizeBtn')?.addEventListener('click', () => ipcRenderer.send('minimize-window'));
        document.getElementById('maximizeBtn')?.addEventListener('click', () => ipcRenderer.send('maximize-window'));
        document.getElementById('closeBtn')?.addEventListener('click', () => ipcRenderer.send('close-window'));
        document.getElementById('backBtn')?.addEventListener('click', () => goHome());

        const editor = document.getElementById('richTextEditor');
        const contextMenu = document.getElementById('contextMenu');
        const devModal = document.getElementById('devModal');
        const settingsModal = document.getElementById('settingsModal');
        const devModalOverlay = document.getElementById('devModalOverlay');
        const closeSettingsBtn = document.getElementById('closeSettingsBtn');
        const editorSidebarVisibleToggle = document.getElementById('editorSidebarVisibleToggle');
        const settingsChoiceButtons = document.querySelectorAll('.settings-choice-btn');
        const sidebarSearchBtn = document.getElementById('sidebarSearchBtn');
        const sidebarSearchPanel = document.getElementById('sidebarSearchPanel');
        const sidebarSearchForm = document.getElementById('sidebarSearchForm');
        const sidebarSearchInput = document.getElementById('sidebarSearchInput');
        const sidebarSearchEmpty = document.getElementById('sidebarSearchEmpty');
        const recentFilesTitle = document.getElementById('recentFilesTitle');
        const MODAL_ANIMATION_MS = 260;
        const DEFAULT_RECENT_FILES_TITLE = recentFilesTitle?.textContent ?? 'Recent files';
        const searchableNoteRows = Array.from(document.querySelectorAll('.searchable-note-row'));
        const demoNoteRows = Array.from(document.querySelectorAll('.demo-note-row'));
        let isSidebarSearchOpen = false;
        let activeModal = null;
        
        // Открытие меню
        editor.addEventListener('contextmenu', function (e) {
            e.preventDefault();
            const selection = window.getSelection();
            if (selection.toString().length > 0) {
                // Скрываем предыдущее меню (снимаем active)
                contextMenu.classList.remove('active');
                // Позиционируем
                contextMenu.style.left = e.pageX + 'px';
                contextMenu.style.top = e.pageY + 'px';
                // Показываем с анимацией
                contextMenu.classList.add('active');
            }
        });

        // Закрытие меню при клике вне его
        document.addEventListener('click', function (e) {
            if (!contextMenu.contains(e.target)) {
                contextMenu.classList.remove('active');
            }
        });

        // Предотвращаем закрытие при клике на само меню
        contextMenu.addEventListener('click', function (e) {
            e.stopPropagation();
        });

        // Улучшенная функция применения стилей (без багов при наложении)
        // ЗАМЕНИТЬ ЭТОТ БЛОК:
// function applyStyleToSelection(styleClass) { ... }
// function colorText(color) { ... }
// function changeFontSize(size) { ... }

// НА ЭТОТ:
function applyStyleToSelection(styleClass) {
    const selection = window.getSelection();
    if (selection.rangeCount === 0 || selection.isCollapsed) {
        document.getElementById('contextMenu').style.display = 'none';
        return;
    }

    const range = selection.getRangeAt(0);
    const selectedText = range.toString();
    if (!selectedText) return;

    // Ищем, не находимся ли мы уже внутри <span>
    let parentSpan = range.commonAncestorContainer;
    if (parentSpan.nodeType === 3) { // Если это текстовая нода
        parentSpan = parentSpan.parentElement;
    }

    const isColorClass = ['red', 'blue', 'green', 'yellow', 'purple', 'white'].includes(styleClass);
    const isSizeClass = styleClass.startsWith('font-');

    // Если выделение находится ровно внутри существующего span, обновляем классы
    if (parentSpan && parentSpan.tagName === 'SPAN' && parentSpan.closest('#richTextEditor')) {
        let classes = Array.from(parentSpan.classList);
        
        // Убираем старый цвет или размер, чтобы они не конфликтовали
        if (isColorClass) {
            classes = classes.filter(c => !['red', 'blue', 'green', 'yellow', 'purple', 'white'].includes(c));
        }
        if (isSizeClass) {
            classes = classes.filter(c => !c.startsWith('font-'));
        }
        
        classes.push(styleClass);
        parentSpan.className = classes.join(' ').trim();
    } else {
        // Иначе создаем новый аккуратный span вокруг текста
        const span = document.createElement('span');
        span.className = styleClass;
        span.appendChild(range.extractContents());
        range.insertNode(span);
    }

    // Убираем выделение и прячем меню
    selection.removeAllRanges();
}

function colorText(color) { applyStyleToSelection(color); }
function changeFontSize(size) { applyStyleToSelection('font-' + size); }

        function saveNote() {
            document.getElementById('NoteContent').value = editor.innerHTML;
            document.forms[0].submit();
        }

        function goHome() {
            window.location.href = "/MainScreen";
        }

        function goToNewNote() {
            window.location.href = newNoteUrl;
        }

        function resetSidebarSearchResults() {
            searchableNoteRows.forEach((row) => {
                row.hidden = false;
            });

            demoNoteRows.forEach((row) => {
                row.hidden = false;
            });

            if (sidebarSearchEmpty) {
                sidebarSearchEmpty.hidden = true;
            }

            if (recentFilesTitle) {
                recentFilesTitle.textContent = DEFAULT_RECENT_FILES_TITLE;
            }
        }

        function runSidebarSearch() {
            const query = (sidebarSearchInput?.value ?? '').trim().toLowerCase();

            if (!query) {
                resetSidebarSearchResults();
                return;
            }

            let matchedCount = 0;

            searchableNoteRows.forEach((row) => {
                const noteTitle = (row.dataset.noteTitle ?? '').toLowerCase();
                const isMatch = noteTitle.includes(query);
                row.hidden = !isMatch;

                if (isMatch) {
                    matchedCount += 1;
                }
            });

            demoNoteRows.forEach((row) => {
                row.hidden = true;
            });

            if (sidebarSearchEmpty) {
                sidebarSearchEmpty.hidden = matchedCount > 0;
            }

            if (recentFilesTitle) {
                recentFilesTitle.textContent = `Search results (${matchedCount})`;
            }
        }

        function toggleSidebarSearch(forceOpen) {
            if (!sidebarSearchPanel) {
                return;
            }

            const nextOpenState = typeof forceOpen === 'boolean' ? forceOpen : !isSidebarSearchOpen;
            isSidebarSearchOpen = nextOpenState;

            sidebarSearchPanel.classList.toggle('is-open', isSidebarSearchOpen);
            sidebarSearchPanel.setAttribute('aria-hidden', isSidebarSearchOpen ? 'false' : 'true');
            sidebarSearchBtn?.classList.toggle('is-active', isSidebarSearchOpen);

            if (isSidebarSearchOpen) {
                requestAnimationFrame(() => sidebarSearchInput?.focus());
                return;
            }

            if (sidebarSearchInput) {
                sidebarSearchInput.value = '';
            }

            resetSidebarSearchResults();
        }

        function persistUiSettings(nextSettings) {
            uiSettings = uiSettingsApi?.write(nextSettings) ?? { ...uiSettings, ...nextSettings };
            return uiSettings;
        }

        function syncSettingsControls() {
            settingsChoiceButtons.forEach((button) => {
                const isActive = uiSettings[button.dataset.setting] === button.dataset.value;
                button.classList.toggle('is-active', isActive);
                button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
            });

            if (editorSidebarVisibleToggle) {
                editorSidebarVisibleToggle.checked = uiSettings.editorSidebarVisible;
            }
        }

        // Логика сайдбара
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        let isCollapsed = !uiSettings.editorSidebarVisible;

        function setSidebarCollapsed(nextCollapsed) {
            isCollapsed = nextCollapsed;
            sidebar.classList.toggle('collapsed', isCollapsed);
            toggleBtn.classList.toggle('collapsed', isCollapsed);
            document.body.classList.toggle('sidebar-collapsed', isCollapsed);
        }

        setSidebarCollapsed(isCollapsed);
        syncSettingsControls();

        toggleBtn.addEventListener('click', () => {
            setSidebarCollapsed(!isCollapsed);
        });

        if (sidebarSearchForm) {
            sidebarSearchForm.addEventListener('submit', (event) => {
                event.preventDefault();
                runSidebarSearch();
            });
        }

        if (sidebarSearchInput) {
            sidebarSearchInput.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    runSidebarSearch();
                    return;
                }

                if (event.key === 'Escape') {
                    event.preventDefault();
                    toggleSidebarSearch(false);
                }
            });
        }

        function showDevModal() {
            openModal(devModal);
        }

        function showSettingsModal() {
            openModal(settingsModal);
        }

        function openModal(modalElement) {
            if (!modalElement) {
                return;
            }

            if (activeModal && activeModal !== modalElement) {
                closeModal(activeModal, true);
            }

            activeModal = modalElement;
            modalElement.hidden = false;
            devModalOverlay.classList.add('is-visible');
            modalElement.classList.remove('is-closing');
            modalElement.classList.add('is-active');
            modalElement.setAttribute('aria-hidden', 'false');
            syncModalVisibilityState();
        }

        function closeModal(modalElement, instantly = false) {
            if (!modalElement) {
                return;
            }

            modalElement.setAttribute('aria-hidden', 'true');

            if (instantly) {
                modalElement.classList.remove('is-active');
                modalElement.classList.remove('is-closing');
                modalElement.hidden = true;
            } else {
                modalElement.classList.remove('is-active');
                modalElement.classList.add('is-closing');

                setTimeout(() => {
                    modalElement.classList.remove('is-closing');
                    modalElement.hidden = true;

                    if (activeModal === modalElement) {
                        activeModal = null;
                    }

                    if (!isAnyModalVisible()) {
                        devModalOverlay.classList.remove('is-visible');
                    }

                    syncModalVisibilityState();
                }, MODAL_ANIMATION_MS);
            }

            if (activeModal === modalElement) {
                activeModal = null;
            }

            if (!isAnyModalVisible()) {
                devModalOverlay.classList.remove('is-visible');
            }

            syncModalVisibilityState();
        }

        function isAnyModalVisible() {
            return devModal.classList.contains('is-active')
                || devModal.classList.contains('is-closing')
                || settingsModal.classList.contains('is-active')
                || settingsModal.classList.contains('is-closing');
        }

        function syncModalVisibilityState() {
            document.body.classList.toggle('modal-open', isAnyModalVisible());
        }

        settingsChoiceButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const settingName = button.dataset.setting;
                const settingValue = button.dataset.value;

                if (!settingName || !settingValue) {
                    return;
                }

                persistUiSettings({ [settingName]: settingValue });
                syncSettingsControls();
            });
        });

        if (editorSidebarVisibleToggle) {
            editorSidebarVisibleToggle.addEventListener('change', (event) => {
                const nextValue = Boolean(event.target.checked);
                persistUiSettings({ editorSidebarVisible: nextValue });
                setSidebarCollapsed(!nextValue);
                syncSettingsControls();
            });
        }

        if (closeSettingsBtn) {
            closeSettingsBtn.addEventListener('click', () => closeModal(settingsModal));
        }

        devModalOverlay.addEventListener('click', () => {
            if (activeModal) {
                closeModal(activeModal);
                return;
            }

            closeModal(devModal, true);
            closeModal(settingsModal, true);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                if (activeModal) {
                    closeModal(activeModal);
                    return;
                }

                closeModal(devModal, true);
                closeModal(settingsModal, true);
            }
        });
    </script>
</body>
