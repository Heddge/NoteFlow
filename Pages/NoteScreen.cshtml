@page "{notePath}"
@using NoteFlow.Models
@using NoteFlow.Pages;
@using NoteFlow.Helpers;
@model NoteFlow.Pages.NoteScreenModel;
@{
    ViewData["Title"] = "NoteScreen";
    Layout = null;
}

<!DOCTYPE html>
<head>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/NoteScreen.css">
</head>

<body>
    <nav class="top-bar">
        @if (PlatformHelper.IsMacOS)
        {
            <div class="top-bar-actions macos-buttons">
                <button class="nav-buttons" title="На главную" id="backBtn">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button class="nav-buttons close-btn" id="closeBtn">
                    <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="#FF5F57" /></svg>
                </button>
                <button class="nav-buttons" id="minimizeBtn">
                    <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="#FFBD2E" /></svg>
                </button>
                <button class="nav-buttons" id="maximizeBtn">
                    <svg width="12" height="12" viewBox="0 0 12 12"><circle cx="6" cy="6" r="6" fill="#28CA42" /></svg>
                </button>
            </div>
        }
        else
        {
            <div class="top-bar-actions windows-buttons">
                <button class="nav-buttons" title="На главную" id="backBtn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M19 12H5M12 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button class="nav-buttons" id="minimizeBtn">
                    <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M5 12h14" stroke-width="2" /></svg>
                </button>
                <button class="nav-buttons" id="maximizeBtn">
                    <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="18" height="18" rx="2" stroke-width="2" /></svg>
                </button>
                <button class="nav-buttons close-btn" id="closeBtn">
                    <svg width="32" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 6L6 18M6 6l12 12" stroke-width="2" /></svg>
                </button>
            </div>
        }
    </nav>

    <div id="contextMenu" class="context-menu">
        <button onclick="colorText('red')">Красный</button>
        <button onclick="colorText('blue')">Синий</button>
        <button onclick="colorText('green')">Зеленый</button>
        <button onclick="colorText('yellow')">Желтый</button>
        <button onclick="colorText('purple')">Фиолетовый</button>
        <button onclick="colorText('white')">Белый</button>
        <hr>
        <button onclick="changeFontSize('plain')">Текст</button>
        <button onclick="changeFontSize('big')">Заголовок 2</button>
        <button onclick="changeFontSize('very-big')">Заголовок 1</button>
    </div>

    <div class="main-content" style="overflow-y: visible">
        <form method="post" asp-page-handler="CreateOrEditNote">
            <input type="hidden" name="path" value="@Model._path" />
            <input type="Text" asp-for="NoteTitle" class="note-title-input" placeholder="Новая заметка" maxlength="35" />
            <input asp-for="NoteContent" type="hidden" id="NoteContent" />

            <div class="editor-container">
                @* ВАЖНО: тег ниже в одну строку без пробелов, чтобы работал плейсхолдер *@
                <div id="richTextEditor" contenteditable="true" data-placeholder="Введите ваш текст...">@Html.Raw(Model.NoteContent)</div>
            </div>
            <button type="button" onclick="saveNote()" class="save-button">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#cccccc" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14,2 14,8 20,8" />
                    <line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10,9 9,9 9,11" />
                </svg>
            </button>
        </form>

        <form method="post">
            <input type="hidden" name="path" value="@Model._path"/>
            <button asp-page-handler="DeleteNote" type="submit" class="delete-button" style="bottom: 75px;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#cccccc" stroke-width="1.5">
                    <path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    <line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/>
                </svg>
            </button>
        </form>
    </div>

    <div id="devModal" class="dev-modal"><div class="dev-modal-content">В разработке...</div></div>
    <div id="devModalOverlay" class="dev-modal-overlay"></div>

    <button id="toggleSidebarBtn" class="toggle-sidebar-btn">
        <div class="toggle-icon">
            <div class="toggle-icon-line"></div><div class="toggle-icon-line"></div><div class="toggle-icon-line"></div>
        </div>
    </button>

    <aside id="sidebar" class="sidebar">
        <div class="sidebar-section">
            <div class="sidebar-item" onclick="showDevModal()">
                <div class="sidebar-icon"><svg width="22" height="22" viewBox="0 0 27 27" fill="none"><circle cx="11" cy="11" r="8" stroke="#A6A6A6" stroke-width="2"/><path d="M18.5 17.5L25 24" stroke="#A6A6A6" stroke-width="2"/></svg></div>
                <div class="sidebar-title">Поиск</div>
            </div>
            <div class="sidebar-item" onclick="showDevModal()">
                <div class="sidebar-icon"><svg width="22" height="22" viewBox="0 0 27 27" fill="none"><rect x="4" y="8" width="19" height="2" fill="#A6A6A6"/><rect x="4" y="13" width="19" height="2" fill="#A6A6A6"/><rect x="4" y="18" width="19" height="2" fill="#A6A6A6"/></svg></div>
                <div class="sidebar-title">Меню</div>
            </div>
            <div class="sidebar-item" onclick="showDevModal()">
                <div class="sidebar-icon"><svg width="22" height="22" viewBox="0 0 27 27" fill="none"><circle cx="13.5" cy="9" r="5" stroke="#A6A6A6" stroke-width="2"/><path d="M5 23C5 18.5 9 15 13.5 15C18 15 22 18.5 22 23" stroke="#A6A6A6" stroke-width="2"/></svg></div>
                <div class="sidebar-title">Аккаунт</div>
            </div>
            <div class="sidebar-item" onclick="showDevModal()">
                <div class="sidebar-icon">
                    <svg width="27" height="27" viewBox="0 0 27 27" fill="none">
                        <path d="M13.5 22L6.5 15.5C4 13 4 9 6.5 6.5C9 4 13 4 15.5 6.5C18 9 18 13 15.5 15.5L13.5 17.5"
                            stroke="#A6A6A6" stroke-width="2" fill="none" />
                    </svg>
                </div>
                <div class="sidebar-title">Избранное</div>
            </div>
        </div>

        <div class="recent-files-section">
            <div class="recent-files-title">Недавние файлы</div>
            <div class="file-list" id="recentFilesList">
                @* Место для цикла из бэкенда *@
                @* @foreach (var note in CacheService.RecentNotes) 
                {
                    <div class="file-item" onclick="window.location.href='/NoteScreen?notePath=@note.Path'">
                        <div class="file-icon">N</div>
                        <div class="file-title">@note.Title</div>
                        <form method="post" asp-page-handler="DeleteNote" style="margin:0">
                            <input type="hidden" name="path" value="@note.Path" />
                            <button type="submit" class="file-remove-btn" onclick="event.stopPropagation();">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                            </button>
                        </form>
                    </div>
                } *@

                <div class="file-item" onclick="showDevModal()">
                    <div class="file-icon">N</div>
                    <div class="file-title">Пример заметки</div>
                    <button class="file-remove-btn" onclick="event.stopPropagation();">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </aside>

    <script>
        const { ipcRenderer } = require('electron');

        document.getElementById('minimizeBtn')?.addEventListener('click', () => ipcRenderer.send('minimize-window'));
        document.getElementById('maximizeBtn')?.addEventListener('click', () => ipcRenderer.send('maximize-window'));
        document.getElementById('closeBtn')?.addEventListener('click', () => ipcRenderer.send('close-window'));
        document.getElementById('backBtn')?.addEventListener('click', () => window.location.href = "/MainScreen");

        const editor = document.getElementById('richTextEditor');
        const contextMenu = document.getElementById('contextMenu');
        
        // Открытие меню
        editor.addEventListener('contextmenu', function (e) {
            e.preventDefault();
            const selection = window.getSelection();
            if (selection.toString().length > 0) {
                // Скрываем предыдущее меню (снимаем active)
                contextMenu.classList.remove('active');
                // Позиционируем
                contextMenu.style.left = e.pageX + 'px';
                contextMenu.style.top = e.pageY + 'px';
                // Показываем с анимацией
                contextMenu.classList.add('active');
            }
        });

        // Закрытие меню при клике вне его
        document.addEventListener('click', function (e) {
            if (!contextMenu.contains(e.target)) {
                contextMenu.classList.remove('active');
            }
        });

        // Предотвращаем закрытие при клике на само меню
        contextMenu.addEventListener('click', function (e) {
            e.stopPropagation();
        });

        // Улучшенная функция применения стилей (без багов при наложении)
        // ЗАМЕНИТЬ ЭТОТ БЛОК:
// function applyStyleToSelection(styleClass) { ... }
// function colorText(color) { ... }
// function changeFontSize(size) { ... }

// НА ЭТОТ:
function applyStyleToSelection(styleClass) {
    const selection = window.getSelection();
    if (selection.rangeCount === 0 || selection.isCollapsed) {
        document.getElementById('contextMenu').style.display = 'none';
        return;
    }

    const range = selection.getRangeAt(0);
    const selectedText = range.toString();
    if (!selectedText) return;

    // Ищем, не находимся ли мы уже внутри <span>
    let parentSpan = range.commonAncestorContainer;
    if (parentSpan.nodeType === 3) { // Если это текстовая нода
        parentSpan = parentSpan.parentElement;
    }

    const isColorClass = ['red', 'blue', 'green', 'yellow', 'purple', 'white'].includes(styleClass);
    const isSizeClass = styleClass.startsWith('font-');

    // Если выделение находится ровно внутри существующего span, обновляем классы
    if (parentSpan && parentSpan.tagName === 'SPAN' && parentSpan.closest('#richTextEditor')) {
        let classes = Array.from(parentSpan.classList);
        
        // Убираем старый цвет или размер, чтобы они не конфликтовали
        if (isColorClass) {
            classes = classes.filter(c => !['red', 'blue', 'green', 'yellow', 'purple', 'white'].includes(c));
        }
        if (isSizeClass) {
            classes = classes.filter(c => !c.startsWith('font-'));
        }
        
        classes.push(styleClass);
        parentSpan.className = classes.join(' ').trim();
    } else {
        // Иначе создаем новый аккуратный span вокруг текста
        const span = document.createElement('span');
        span.className = styleClass;
        span.appendChild(range.extractContents());
        range.insertNode(span);
    }

    // Убираем выделение и прячем меню
    selection.removeAllRanges();
}

function colorText(color) { applyStyleToSelection(color); }
function changeFontSize(size) { applyStyleToSelection('font-' + size); }

        function saveNote() {
            document.getElementById('NoteContent').value = editor.innerHTML;
            document.forms[0].submit();
        }

        // Логика сайдбара
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        let isCollapsed = false;

        toggleBtn.addEventListener('click', () => {
            isCollapsed = !isCollapsed;
            sidebar.classList.toggle('collapsed', isCollapsed);
            toggleBtn.classList.toggle('collapsed', isCollapsed);
            document.body.classList.toggle('sidebar-collapsed', isCollapsed);
        });

        // Модалка "В разработке"
        function showDevModal() {
            document.getElementById('devModal').style.display = 'block';
            document.getElementById('devModalOverlay').style.display = 'block';
        }

        document.getElementById('devModalOverlay').addEventListener('click', () => {
            document.getElementById('devModal').style.display = 'none';
            document.getElementById('devModalOverlay').style.display = 'none';
        });
    </script>
</body>